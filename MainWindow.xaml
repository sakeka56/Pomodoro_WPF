<Window x:Class="Clock_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Clock_WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="400" Width="800">
    <Grid>
        <Image x:Name="LeftImage" HorizontalAlignment="Left" Height="304" VerticalAlignment="Top" Width="304" Source="/时钟.png" Margin="10,40,0,0"/>
        <Label x:Name="TitleLabel" Content="Label" HorizontalAlignment="Center" VerticalAlignment="Top" Width="800"/>
        <ListView d:ItemsSource="{d:SampleData ItemCount=5}" Margin="294,59,338,57" SelectionChanged="ListView_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn/>
                </GridView>
            </ListView.View>
        </ListView>
        <Grid Margin="0,59,48,0" Height="316" VerticalAlignment="Top" HorizontalAlignment="Right" Width="253">
            <Button x:Name="YesButton" Content="确认" Margin="122,200,36,45" Click="StartButton_Click"/>
            <TextBox x:Name="Num1TextBox" HorizontalAlignment="Left" Margin="-1,2,0,0" TextWrapping="Wrap" Text="0"  VerticalAlignment="Top" Width="218" Height="75" TextChanged="Num1TextBox_TextChanged" PreviewTextInput="NumPreviewInput" FontSize="48" FontFamily="Noto Sans SC Black" TextAlignment="Right"/>
            <TextBox x:Name="Num2TextBox" HorizontalAlignment="Left" Margin="-2,108,0,0" TextWrapping="Wrap" Text="0"  VerticalAlignment="Top" Width="218" Height="75" TextChanged="Num2TextBox_TextChanged" PreviewTextInput="NumPreviewInput" FontSize="48" FontFamily="Noto Sans SC Black" TextAlignment="Right"/>
            <TextBlock HorizontalAlignment="Left" Margin="227,39,0,-58"  TextAlignment="Center" FontSize="24"><Run Language="zh-cn" Text="分"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="227,135,0,-58"  TextAlignment="Center" FontSize="24"><Run Language="zh-cn" Text="分"/></TextBlock>
            <TextBox x:Name="Num3TextBox" HorizontalAlignment="Left" Margin="-1,200,0,45" TextWrapping="Wrap" Text="0&#xA;" Width="103" TextChanged="Num3TextBox_TextChanged" PreviewTextInput="NumPreviewInput" FontSize="48" FontFamily="Noto Sans SC Black" TextAlignment="Center"/>
        </Grid>

    </Grid>
</Window>
